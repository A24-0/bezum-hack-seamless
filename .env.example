SECRET_KEY=change_me_use_long_random_string
OPENAI_API_KEY=
# HuggingFace Inference (для AI-бота, если OPENAI_API_KEY пустой)
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Ollama (локально, бесплатный вариант)
# Если Ollama запущен на хосте: `http://localhost:11434`
# Для Docker-контейнера обычно доступ через `host.docker.internal`.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
JITSI_DOMAIN=meet.jit.si
SEED_DEMO_DATA=false
POSTGRES_DB=seamless
POSTGRES_USER=seamless
POSTGRES_PASSWORD=seamless
BACKEND_HOST_PORT=8001
FRONTEND_HOST_PORT=8080
DOMAIN=localhost

# CORS (security: don't use wildcard by default)
CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_HEADERS=Authorization,Content-Type

# GitHub CI/CD (Pull Requests API + webhook)
# GITHUB_TOKEN=GitHub token with access to repos (repo scope)
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
# Secret token для webhook (X-Hub-Signature-256 в GitHub)
GITHUB_WEBHOOK_SECRET=

# GitLab CI/CD (fallback, если не настроен GitHub)
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_WEBHOOK_SECRET=

