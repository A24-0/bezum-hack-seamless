SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
OPENAI_API_KEY=
# HuggingFace Inference (опционально, если OPENAI_API_KEY пустой)
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# Ollama (локально, бесплатный вариант)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
JITSI_DOMAIN=meet.jit.si
POSTGRES_DB=seamless
POSTGRES_USER=seamless
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DOMAIN=app.example.com
SEED_DEMO_DATA=false

# CORS (security)
CORS_ALLOW_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_HEADERS=Authorization,Content-Type

# GitHub CI/CD
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=

# GitLab CI/CD (fallback)
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_WEBHOOK_SECRET=
